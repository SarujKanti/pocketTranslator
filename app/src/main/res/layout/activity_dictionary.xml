<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    tools:context=".activity.DictionaryActivity">

    <!-- ── Gradient header strip ── -->
    <View
        android:id="@+id/viewHeader"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_gradient_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App title (sits on top of gradient) -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:text="@string/app_name"
        android:fontFamily="@font/robo_600"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/viewHeader"
        app:layout_constraintBottom_toBottomOf="@id/viewHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Info logo (sits on top of gradient) -->
    <ImageView
        android:id="@+id/ivInfoLogo"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/dictionary"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/viewHeader"
        app:layout_constraintBottom_toBottomOf="@id/viewHeader"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Input Card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/viewHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <!-- "English" label chip -->
            <TextView
                android:id="@+id/tvInputLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:background="#E8EEFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:hint="@string/enter_english_text"
                android:textSize="16sp"
                android:paddingStart="4dp"
                android:fontFamily="@font/robo_600"
                android:inputType="text"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toBottomOf="@id/tvInputLabel"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/layoutActions" />

            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageButton
                    android:id="@+id/btnSpeakInput"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:contentDescription="Pronounce"
                    app:tint="@color/primary" />

                <ImageButton
                    android:id="@+id/btnClearInput"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@android:color/holo_red_dark"
                    android:contentDescription="Clear" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- ── Language Selection Card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLanguage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/cardInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvLanguageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/translate_to"
                android:fontFamily="@font/robo_600"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ── Translate Button ── -->
    <Button
        android:id="@+id/btnTranslate"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:text="@string/translate"
        android:fontFamily="@font/robo_600"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_gradient_button"
        android:elevation="8dp"
        app:backgroundTint="@null"
        app:layout_constraintTop_toBottomOf="@id/cardLanguage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Result Card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/bg_result_card"
        app:layout_constraintTop_toBottomOf="@id/btnTranslate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- "Translation" chip label -->
            <TextView
                android:id="@+id/tvResultLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Translation"
                android:textSize="11sp"
                android:textColor="@color/accent_purple"
                android:textStyle="bold"
                android:background="#EDE8FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/robo_600"
                android:hint="@string/translated_text_"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                app:layout_constraintTop_toBottomOf="@id/tvResultLabel"
                app:layout_constraintEnd_toStartOf="@id/layoutResultActions"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvPronunciation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/robo_600"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/layoutResultActions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvResult" />

            <LinearLayout
                android:id="@+id/layoutResultActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btnSpeak"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:contentDescription="Pronounce"
                    app:tint="@color/accent_purple" />

                <ImageButton
                    android:id="@+id/btnClear"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@android:color/holo_red_dark"
                    android:contentDescription="Clear" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- ── Word Details List ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWordDetails"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/cardResult"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/progressWordDetails"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateDrawable="@drawable/progressbar_custome"
        app:layout_constraintTop_toTopOf="@id/rvWordDetails"
        app:layout_constraintBottom_toBottomOf="@id/rvWordDetails"
        app:layout_constraintStart_toStartOf="@id/rvWordDetails"
        app:layout_constraintEnd_toEndOf="@id/rvWordDetails" />

</androidx.constraintlayout.widget.ConstraintLayout>
